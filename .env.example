# Copy to .env.local and fill in the blanks. Never commit .env.local.
# Only the four secret slots need to be supplied — the SMTP host / port /
# user / from-name defaults are correct for the live setup but feel free
# to override per environment.

# Supabase  ───────────────────────────────────────────────────────────
# Project Settings → API. The anon key is safe to expose in the browser;
# the service role key is NOT — Edge Functions only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (DreamHost)  ───────────────────────────────────────────────────
# scripts/set-supabase-secrets.sh reads these and pushes them as
# Edge Function secrets in one shot.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
